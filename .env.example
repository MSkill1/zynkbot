# =============================================================================
# ZYNKBOT CONFIGURATION REFERENCE
# =============================================================================
# This file documents the environment variables Zynkbot uses.
# End users do not need to edit this — the app manages configuration through
# the Settings UI. Developers running from source can use this as a reference
# for what variables to expect.
# WARNING: Never commit your actual .env file - it's excluded by .gitignore

# -----------------------------------------------------------------------------
# LLM Backend Selection (Privacy-First Default)
# -----------------------------------------------------------------------------
# Options: "local", "openai", "anthropic"
# - local: Privacy-first, runs on your machine (requires model download)
# - openai/anthropic: API-based (faster setup, costs money, less privacy)
ZYNK_MODEL_BACKEND=local

# Local model path (only needed if ZYNK_MODEL_BACKEND=local)
# Download .gguf models from: https://huggingface.co/TheBloke
# Place .gguf files in the models/ directory
LOCAL_MODEL_PATH=models/tinyllama-1.1b.Q4_K_M.gguf

# API keys (optional - only needed if you want to use API models)
# Get OpenAI key from: https://platform.openai.com/api-keys
# Get Anthropic key from: https://console.anthropic.com/settings/keys
# Get xAI (Grok) key from: https://console.x.ai/
#
# 🔴 SECURITY WARNING:
# - NEVER commit your .env file with real keys!
# - Keys grant access to paid APIs - keep them secret
# - If leaked, revoke immediately at provider's dashboard
# - Leave blank if using local-only mode
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=

# -----------------------------------------------------------------------------
# Containment Mode (Safety Layer)
# -----------------------------------------------------------------------------
# Options: "witness", "sovereign", "guardian", "child", "hipaa", "default"
# - witness: No enforcement (development only)
# - sovereign: Warn on unsafe content
# - guardian: Block unsafe content (recommended default)
# - child: Strict filtering for minors (⚠️ REQUIRES OpenAI API!)
# - hipaa: HIPAA-compliant medical discussions (PHI protection, ephemeral memory)
#
# 🔴 CRITICAL - CHILD MODE REQUIREMENT:
# Child mode REQUIRES OpenAI API for content classification!
# Local fallback (toxic-bert) is NOT sufficient for child safety.
# If using child mode, you MUST set OPENAI_API_KEY above.
#
# 🟡 HIPAA MODE DISCLAIMER:
# HIPAA mode provides PHI detection and ephemeral memory, but is NOT
# legally certified for HIPAA compliance. Consult a compliance attorney
# for healthcare use.
ZYNK_CONTAINMENT_MODE=guardian

# -----------------------------------------------------------------------------
# ZynkSync (Local Network Device Sync)
# -----------------------------------------------------------------------------
ZYNKSYNC_AUTO_SYNC=true
ZYNKSYNC_SYNC_INTERVAL=60
