{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zynkbot",
  "version": "0.1.0",
  "identifier": "com.zynkbot.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run start:tauri",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Zynkbot",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "label": "main"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-capability",
          "windows": ["main"],
          "permissions": [
            {
              "identifier": "shell:allow-open",
              "allow": [
                { "path": "**" }
              ]
            },
            "shell:default",
            "core:event:allow-listen",
            "core:event:allow-emit",
            "core:event:default",
            "core:window:allow-set-title",
            "core:window:default",
            "dialog:allow-open",
            "dialog:default",
            "core:webview:allow-internal-toggle-devtools",
            "core:webview:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
